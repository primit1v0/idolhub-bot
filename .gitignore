# =============================================================================
# idolhub — .gitignore
# Secrets and machine-local state must never be committed.
# =============================================================================

# --- Python ---
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
build/
dist/
*.egg-info/
*.egg
MANIFEST

# --- Virtual environment (uv) ---
.venv/
venv/
env/
ENV/

# --- uv.lock: DI-COMMIT untuk reproducible builds ---
# uv.lock  ← jangan uncomment ini

# --- Secrets & environment ---
# .env TIDAK BOLEH ada di sini — inject via systemd EnvironmentFile
.env
.env.*
*.env
secrets.env
*.secret
*.pem
*.key
*.p12
*.pfx
*.jks
*.keystore
credentials.json
credentials.*.json
secrets.json
secrets.*.json

# --- Runtime data ---
data/
*.db
*.db-*
*.sqlite
*.sqlite-*
*.sqlite3
*.sqlite3-*
chroma/
*.faiss

# --- Logs ---
logs/
*.log
*.log.*

# --- Local configuration ---
config.json
config.local.json
config.override.json

# --- IDE & editor ---
.vscode/
.idea/
.cursor/
*.swp
*.swo
*~

# --- OS ---
.DS_Store
.DS_Store?
._*
.Spotlight-V7
.Trashes
ehthumbs.db
Thumbs.db

# --- Testing ---
.pytest_cache/
.coverage
htmlcov/
.tox/

# --- Custom local tools & runtime directories ---
.audit-tools/
workspace/

# --- Audit reports (generated) ---
hasilaudit.md
